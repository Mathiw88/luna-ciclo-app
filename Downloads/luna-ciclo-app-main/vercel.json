{
  "functions": {
    "api/chat.js": { "runtime": "@vercel/node@3" },
    "api/sw.js": { "runtime": "@vercel/node@3" },
    "api/icon.js": { "runtime": "@vercel/node@3" }
  },
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/sw.js", "dest": "/api/sw.js" },
    { "src": "/apple-touch-icon.png", "dest": "/api/icon.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
