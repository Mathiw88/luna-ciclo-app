{
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/sw.js", "dest": "/api/sw.js" },
    { "src": "/apple-touch-icon.png", "dest": "/api/icon.js" },
    { "src": "/icon-192.png", "dest": "/api/icon192.js" },
    { "src": "/icon-512.png", "dest": "/api/icon512.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
